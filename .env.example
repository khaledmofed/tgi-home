# External portal URLs (private backoffice, not part of this project).
# The Login/Register/Dashboard buttons never link anywhere hardcoded in
# components — they always read from here via src/config/env.ts.
VITE_LOGIN_URL=http://localhost:3000/login
VITE_USER_DASHBOARD_URL=http://localhost:3000/dashboard
VITE_REGISTER_URL=http://localhost:3000/register

# Contact button/link target. Can be an internal route (default) or an
# absolute URL if the client ever wants Contact to point elsewhere.
VITE_CONTACT_URL=/contact

# Real contact-form backend endpoint. Leave empty to use the built-in demo
# submission (no data is sent anywhere, see README "Connecting a real
# contact API").
VITE_CONTACT_API_URL=

# Master switch for the language selector. The UI ships with a full list of
# languages, but no real translations exist yet, so this defaults to false
# (every language except English renders disabled). Flip to true only once
# real translations are wired up.
VITE_ENABLE_TRANSLATIONS=false